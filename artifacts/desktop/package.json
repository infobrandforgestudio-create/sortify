{
  "name": "@workspace/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Sortify — AI-powered email organizer",
  "author": "Sortify",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "node ./build.mjs",
    "build:renderer": "pnpm --filter @workspace/email-organizer run build:desktop",
    "build": "pnpm run build:renderer && pnpm run build:main",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "package": "pnpm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "imapflow": "^1.4.1",
    "mailparser": "^3.9.10",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mailparser": "^3.4.6",
    "@types/node": "catalog:",
    "@workspace/api-zod": "workspace:*",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "0.27.3",
    "express": "^5.2.1",
    "openai": "^6.42.0",
    "typescript": "~5.9.3",
    "zod": "catalog:"
  }
}
